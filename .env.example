# Constellation environment — copy to `.env` and fill in only what you need.
# The app runs fully offline on synthetic sample data with every IQ layer MOCKED.
# Prefer DefaultAzureCredential (az login / managed identity) over secrets when going live.

# --- Foundry IQ (core grounded reasoning) ---
# Leave false to use the deterministic mock. Set true only with a real Azure AI Foundry project.
FOUNDRY_LIVE=false
AZURE_AI_FOUNDRY_ENDPOINT=
AZURE_AI_FOUNDRY_PROJECT=
AZURE_AI_FOUNDRY_DEPLOYMENT=

# --- Work IQ (Microsoft Graph: meetings, owners, recency) ---
WORKIQ_LIVE=false

# --- Fabric IQ (OneLake / SQL recurrence + velocity analytics) ---
FABRICIQ_LIVE=false

# --- API server ---
PORT=3001
WEB_ORIGIN=http://localhost:5173

# --- Data locations (defaults are fine; override only if you move folders) ---
# DATA_DIR=sample-data
# GRAPH_PATH=data/graph.json
